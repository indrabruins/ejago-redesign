---
const services = [
  {
    title: "Brand Strategy",
    outcome: "Turn anonymous into unforgettable",
    price: "From $8,500/mo",
    metric: "64% more conversions",
    icon: "◇",
    iconImg: "/assets/icon-brand-strategy.png",
  },
  {
    title: "Web & App",
    outcome: "Sites so good they steal attention",
    price: "From $25,000",
    metric: "4× faster load times",
    icon: "◈",
    iconImg: "/assets/icon-web-app.png",
  },
  {
    title: "Growth Marketing",
    outcome: "Revenue, not vanity metrics",
    price: "From $8,500/mo",
    metric: "$47M revenue moved",
    icon: "◆",
    iconImg: "/assets/icon-growth-marketing.png",
  },
  {
    title: "AI Consulting",
    outcome: "AI your competitors aren't using yet",
    price: "From $15,000",
    metric: "3× ROI average",
    icon: "◉",
    iconImg: "/assets/icon-ai-consulting.png",
  },
  {
    title: "ERP Integration",
    outcome: "The invisible infrastructure that doubles revenue",
    price: "From $30,000",
    metric: "90% efficiency gains",
    icon: "▣",
    iconImg: "/assets/icon-erp-integration.png",
  },
  {
    title: "Development",
    outcome: "Custom build. Zero compromise.",
    price: "From $20,000",
    metric: "99.9% uptime",
    icon: "◫",
    iconImg: "/assets/icon-development.png",
  },
];
---

<section id="services" class="services-section">
  <!-- Video background -->
  <div class="section-video-bg" aria-hidden="true">
    <video class="section-video" autoplay muted loop playsinline poster="/assets/services-poster.jpg">
      <source src="/assets/videos/services-bg.mp4" type="video/mp4" />
    </video>
    <div class="section-video-overlay"></div>
  </div>
  <div class="container">
    <header class="section-header scroll-reveal">
      <p class="label">What We Do</p>
      <h2 class="title">We don't do "digital marketing."<br />We do customer acquisition engineering.</h2>
      <p class="subtitle">Six ways we turn anonymous visitors into obsessed customers.</p>
    </header>

    <div class="bento-grid">
      {services.map((service, i) => (
        <div class={`service-card card-3d scroll-reveal stagger-${(i % 3) + 1} bento-${['lg','sm','md','lg','sm','md'][i]}`}>
          <div class="card-inner">
            <div class="service-icon-wrap">
              <img src={service.iconImg} alt={service.title} width="48" height="48" loading="lazy" />
            </div>
            <h3 class="service-title">{service.title}</h3>
            <p class="service-outcome">"{service.outcome}"</p>
            <div class="service-metric">
              <span class="metric-value">{service.metric}</span>
            </div>
            <p class="service-price">{service.price}</p>
            <a href="/work" class="service-link">
              See Work
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Guarantee strip -->
    <div class="guarantee-strip scroll-reveal">
      <div class="guarantee-inner">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <p>
          <strong>Results-guaranteed.</strong> If you don't see measurable improvement in 90 days,
          we keep working free until you do.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 100px 0;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }
  .section-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .section-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.12;
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
  }
  .section-video-overlay {
    position: absolute;
    inset: 0;
    background: var(--bg-primary);
    opacity: 0.88;
  }
  .container {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .section-header { text-align: center; margin-bottom: 64px; }
  .label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  .subtitle {
    font-size: 18px;
    color: var(--text-muted);
  }

  /* Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 180px;
    gap: 16px;
  }

  /* Asymmetric bento sizes */
  .bento-lg { grid-column: span 2; grid-row: span 2; }
  .bento-md { grid-column: span 2; grid-row: span 1; }
  .bento-sm { grid-column: span 1; grid-row: span 1; }

  /* The tall AI Consulting card needs 2 rows */
  .bento-tall { grid-row: span 2; }

  @media (max-width: 1024px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
    .bento-lg, .bento-md { grid-column: span 2; }
    .bento-lg { grid-row: span 1; }
    .bento-tall { grid-row: span 1; }
  }
  @media (max-width: 640px) {
    .bento-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .bento-lg, .bento-md, .bento-sm, .bento-tall { grid-column: span 1; grid-row: span 1; }
  }

  /* Service Card */
  .service-card {
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 16px;
    padding: 28px;
    transition: box-shadow 300ms ease, border-color 300ms ease, transform 300ms ease;
    cursor: default;
  }
  .service-card:hover {
    box-shadow: 0 20px 60px rgba(99,102,241,0.14);
    border-color: rgba(99,102,241,0.3);
  }
  .card-inner {
    display: flex;
    flex-direction: column;
    gap: 10px;
    height: 100%;
  }

  /* Icon */
  .service-icon-wrap {
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }
  .service-icon-wrap img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: 12px;
    background: rgba(255,255,255,0.8);
    padding: 2px;
  }
  .service-icon {
    display: block;
    font-size: 28px;
    color: var(--accent-primary);
    transition: color 200ms ease;
    letter-spacing: -2px;
  }

  /* Title */
  .service-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--text-primary);
    line-height: 1.2;
  }

  /* Outcome */
  .service-outcome {
    font-size: 15px;
    color: var(--text-secondary);
    font-style: italic;
    line-height: 1.5;
  }

  /* Metric pill */
  .service-metric {
    display: inline-flex;
    padding: 6px 12px;
    background: var(--accent-primary);
    border-radius: 6px;
    width: fit-content;
  }
  .metric-value {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: white;
  }

  /* Price */
  .service-price {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
    margin-top: auto;
    padding-top: 4px;
  }

  /* Link */
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--accent-primary);
    text-decoration: none;
    transition: gap 200ms ease;
  }
  .service-link:hover { gap: 10px; }

  /* Scroll reveal */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 600ms cubic-bezier(0.16,1,0.3,1), transform 600ms cubic-bezier(0.16,1,0.3,1);
  }
  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .stagger-1 { transition-delay: 0ms; }
  .stagger-2 { transition-delay: 100ms; }
  .stagger-3 { transition-delay: 200ms; }

  /* Guarantee strip */
  .guarantee-strip {
    margin-top: 48px;
    background: var(--accent-primary);
    border-radius: 16px;
    padding: 24px 32px;
  }
  .guarantee-inner {
    display: flex;
    align-items: center;
    gap: 16px;
    max-width: 700px;
    margin: 0 auto;
    color: white;
  }
  .guarantee-inner svg { flex-shrink: 0; opacity: 0.9; }
  .guarantee-inner p { font-size: 15px; line-height: 1.5; }
  .guarantee-inner strong { font-weight: 700; }
  @media (max-width: 640px) { .guarantee-inner { flex-direction: column; text-align: center; } }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal { opacity: 1; transform: none; transition: none; }
    .service-card { transform: none !important; }
  }
</style>

<script>
  // ── 3D Tilt on Service Cards ───────────────────────────────────
  document.querySelectorAll('.service-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      card.style.transform = `perspective(800px) rotateX(${-y * 8}deg) rotateY(${x * 8}deg) translateY(-8px) scale(1.02)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
</script>
