---
---

<section class="hero" id="hero">
  <!-- Video background layer (primary) -->
  <div class="hero-video-layer" id="hero-video-layer" aria-hidden="true">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      poster="/assets/hero-loop-poster.jpg"
    >
      <source src="/assets/videos/hero-bg.mp4" type="video/mp4" />
    </video>
    <!-- Parallax shapes layer -->
    <div class="hero-parallax-video-wrap" aria-hidden="true">
      <video
        class="hero-parallax-video"
        autoplay
        muted
        loop
        playsinline
        poster="/assets/hero-parallax-mid.png"
      >
        <source src="/assets/videos/hero-parallax.mp4" type="video/mp4" />
      </video>
    </div>
    <!-- Fallback: CSS blob if video not ready -->
    <div class="hero-blob-fallback" aria-hidden="true">
      <div class="blob-1"></div>
      <div class="blob-2"></div>
    </div>
  </div>

  <!-- Gradient overlay for text contrast -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Static shapes layer (hidden when video is active) -->
  <div class="hero-shapes-layer" id="hero-shapes-layer" aria-hidden="true">
    <img src="/assets/hero-parallax-mid.png" alt="" loading="eager" />
  </div>

  <div class="hero-inner">
    <!-- Headline with word scramble -->
    <h1 class="hero-headline entry-hero-h1" aria-label="Your Competitors Have Marketing. You Need Obsession.">
      <span class="hero-word" data-word="Your">Your</span>
      <span class="hero-word" data-word="Competitors">Competitors</span>
      <span class="hero-word" data-word="Have">Have</span>
      <span class="hero-word" data-word="Marketing.">Marketing.</span>
      <br />
      <span class="hero-word accent" data-word="You">You</span>
      <span class="hero-word accent" data-word="Need">Need</span>
      <span class="hero-word accent" data-word="Obsession.">Obsession.</span>
    </h1>

    <!-- Subheadline -->
    <p class="hero-sub entry-hero-sub">
      AI-Powered growth for DTC brands who refuse to be forgettable.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas entry-hero-ctas">
      <a href="/contact" class="btn-primary magnetic-btn">
        Start a Project
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/work" class="btn-ghost magnetic-btn">
        See Our Work
      </a>
    </div>

    <!-- Availability badge -->
    <div class="hero-availability entry-hero-avail">
      <span class="avail-dot"></span>
      Currently Accepting 2 New Clients
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <span>Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    overflow: hidden;
    background: var(--bg-primary);
  }

  /* ── Video Layer ── */
  .hero-video-layer {
    position: absolute;
    inset: -15%;
    z-index: 0;
    will-change: transform;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Slight zoom to prevent edge gaps during parallax */
    transform: scale(1.08);
  }

  /* Fallback CSS blobs when video not loaded */
  .hero-blob-fallback {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-blob-fallback.hidden { display: none; }
  .blob-1 {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(99,102,241,0.12) 0%, transparent 70%);
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    animation: blob-drift 12s ease-in-out infinite;
  }
  .blob-2 {
    position: absolute;
    bottom: -15%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(249,115,22,0.08) 0%, transparent 70%);
    border-radius: 40% 60% 70% 30% / 40% 70% 30% 60%;
    animation: blob-drift 15s ease-in-out infinite reverse;
  }
  @keyframes blob-drift {
    0%, 100% { transform: scale(1) translate(0, 0) rotate(0deg); border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    33% { transform: scale(1.05) translate(-20px, 20px) rotate(5deg); border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    66% { transform: scale(1.1) translate(20px, -10px) rotate(-5deg); border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%; }
  }

  /* ── Gradient Overlay (text contrast) ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      135deg,
      rgba(250,249,246,0.55) 0%,
      rgba(250,249,246,0.20) 40%,
      rgba(250,249,246,0.50) 80%,
      rgba(250,249,246,0.80) 100%
    );
    pointer-events: none;
  }

  /* ── Parallax Shapes Layer (mid depth — video) ── */
  .hero-parallax-video-wrap {
    position: absolute;
    inset: -20%;
    z-index: 2;
    will-change: transform;
    pointer-events: none;
  }
  .hero-parallax-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
    mix-blend-mode: multiply;
    transform: scale(1.1);
  }

  /* ── Static shapes layer (fallback when video not loaded) ── */
  .hero-shapes-layer {
    position: absolute;
    inset: -20%;
    z-index: 2;
    will-change: transform;
    pointer-events: none;
  }
  .hero-shapes-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
    mix-blend-mode: multiply;
  }

  /* ── Responsive: disable parallax on mobile ── */
  @media (max-width: 768px) {
    .hero-video-layer,
    .hero-shapes-layer { transform: none !important; }
    .hero-video-layer { inset: 0; }
    .hero-shapes-layer { display: none; }
    .hero-overlay {
      background: linear-gradient(
        to bottom,
        rgba(250,249,246,0.50) 0%,
        rgba(250,249,246,0.15) 60%,
        rgba(250,249,246,0.70) 100%
      );
    }
  }

  /* ── Reduced motion: no parallax ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-video-layer,
    .hero-shapes-layer { transform: none !important; will-change: auto; }
    .blob-1, .blob-2 { animation: none; }
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    text-align: center;
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(44px, 7vw, 88px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 28px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 0.25em;
  }
  .hero-word {
    display: inline-block;
    opacity: 0;
    transition: opacity 0.1s;
  }
  .hero-word.accent {
    color: var(--accent-primary);
  }

  /* Subheadline */
  .hero-sub {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 600ms cubic-bezier(0.16,1,0.3,1), transform 600ms cubic-bezier(0.16,1,0.3,1);
  }
  .hero-sub.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .hero-cta {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 500ms ease, transform 500ms cubic-bezier(0.16,1,0.3,1);
  }
  .hero-cta.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--accent-cta);
    color: white;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    border-radius: 12px;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(249,115,22,0.28);
    transition: transform 200ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 200ms ease;
  }
  .btn-primary:hover {
    transform: scale(1.02) translateY(-2px);
    box-shadow: 0 16px 40px rgba(249,115,22,0.35);
  }
  .btn-primary:active {
    transform: scale(0.97);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: transparent;
    color: var(--text-primary);
    border: 2px solid var(--border);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 200ms ease, background 200ms ease, transform 200ms cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-ghost:hover {
    border-color: var(--accent-primary);
    background: var(--bg-tint);
    transform: scale(1.02);
  }

  /* Availability */
  .hero-availability {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(16,185,129,0.08);
    border: 1px solid rgba(16,185,129,0.25);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent-secondary);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 400ms ease, transform 400ms ease;
  }
  .hero-availability.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .avail-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-secondary);
    border-radius: 50%;
    animation: avail-pulse 2s ease-in-out infinite;
  }
  @keyframes avail-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    animation: scroll-bounce 2s ease-in-out infinite;
    animation-delay: 2s;
    opacity: 0;
    z-index: 3;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-headline { flex-direction: column; gap: 0; }
    .hero-headline br { display: none; }
    .hero-ctas { flex-direction: column; align-items: center; }
    .btn-primary, .btn-ghost { width: 100%; max-width: 320px; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word { opacity: 1 !important; transition: none; }
    .hero-sub, .hero-cta, .hero-availability, .scroll-indicator { animation: none !important; transition: none !important; }
    .blob-1, .blob-2 { animation: none; }
  }
</style>

<script>
  // ── Mouse Parallax on Hero ─────────────────────────────────────
  const videoLayer = document.getElementById('hero-video-layer');
  const parallaxWrap = document.querySelector('.hero-parallax-video-wrap');
  const shapesLayer = document.getElementById('hero-shapes-layer');
  let targetMX = 0, targetMY = 0, curMX = 0, curMY = 0;

  document.addEventListener('mousemove', e => {
    targetMX = (e.clientX / window.innerWidth - 0.5) * 2;
    targetMY = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  function animateMouseParallax() {
    curMX += (targetMX - curMX) * 0.08;
    curMY += (targetMY - curMY) * 0.08;
    if (videoLayer) videoLayer.style.transform = `translate(${curMX * 15}px, ${curMY * 10}px)`;
    if (parallaxWrap) parallaxWrap.style.transform = `translate(${curMX * 25}px, ${curMY * 18}px)`;
    if (shapesLayer) shapesLayer.style.transform = `translate(${curMX * 20}px, ${curMY * 14}px)`;
    requestAnimationFrame(animateMouseParallax);
  }
  animateMouseParallax();

  // ── Hero Parallax on Scroll ──────────────────────────────────────
  const hero = document.getElementById('hero');
  const fallback = document.querySelector('.hero-blob-fallback');
  const video = document.querySelector('.hero-video');

  // Hide CSS fallback once video can play
  if (video) {
    video.addEventListener('canplay', () => {
      fallback?.classList.add('hidden');
    });
  }

  // Parallax: video at 0.3x scroll, shapes at 0.5x scroll
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        if (scrollY < window.innerHeight) {
          if (videoLayer) {
            videoLayer.style.transform = `translateY(${scrollY * 0.3}px)`;
          }
          if (parallaxWrap) {
            parallaxWrap.style.transform = `translateY(${scrollY * 0.5}px)`;
          }
          if (shapesLayer) {
            shapesLayer.style.transform = `translateY(${scrollY * 0.5}px)`;
          }
        }
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
</script>
