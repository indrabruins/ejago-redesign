---
---

<section id="cta" class="cta-section">
  <!-- Video background -->
  <div class="section-video-bg" aria-hidden="true">
    <video poster="/assets/hero-poster.jpg" class="section-video" autoplay muted loop playsinline>
      <source src="/assets/videos/pricing-cta.mp4" type="video/mp4" />
    </video>
    <div class="section-video-overlay"></div>
  </div>
  <div class="cta-blob" aria-hidden="true">
    <div class="blob-light"></div>
  </div>
  <div class="container">
    <h2 class="cta-headline scroll-reveal">Curious? Let's Talk.</h2>

    <div class="cta-buttons scroll-reveal">
      <a href="/contact" class="btn-primary magnetic-btn">
        Book a Call
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/contact" class="btn-ghost magnetic-btn">
        Let's Chat
      </a>
    </div>

    <div class="divider scroll-reveal">
      <span>Not ready to talk?</span>
    </div>

    <!-- Lead magnet -->
    <div class="lead-magnet scroll-reveal">
      <p class="lm-title">Get your free "DTC Growth Audit" — 11 checkpoints:</p>
      <ul class="lm-preview">
        <li>Where you're bleeding revenue (and how to stop it)</li>
        <li>Your channel mix efficiency (are you over-investing in the wrong places?)</li>
        <li>The one change that would double your conversion rate</li>
      </ul>
      <form class="lm-form">
        <div class="lm-input-wrap">
          <input
            type="email"
            class="input"
            placeholder="Enter your email"
            required
            aria-label="Your email address"
          />
          <button type="submit" class="btn-lm">
            Send Me the Audit →
          </button>
        </div>
        <p class="lm-reassure">Free. No pitch. We'll send you a detailed breakdown within 24 hours.</p>
      </form>
    </div>

    <!-- Availability -->
    <div class="cta-availability scroll-reveal">
      <div class="avail-items">
        <div class="avail-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Next available start: <strong class="avail-date-dynamic" id="avail-date-root"></strong>
        </div>
        <div class="avail-sep">·</div>
        <div class="avail-item">
          <span class="avail-dot"></span>
          Currently accepting <strong>2 new clients</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 100px 0;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }
  .section-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .section-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.12;
  }
  .section-video-overlay {
    position: absolute;
    inset: 0;
    background: var(--bg-primary);
    opacity: 0.88;
  }
  .container { position: relative; z-index: 1; }
  .cta-headline, .cta-buttons, .lead-magnet, .cta-availability { position: relative; z-index: 1; }
  .cta-blob {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .blob-light {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(ellipse at center, rgba(99,102,241,0.07) 0%, transparent 70%);
    animation: cta-glow 8s ease-in-out infinite;
  }
  @keyframes cta-glow {
    0%, 100% { transform: translate(-50%,-50%) scale(1); }
    50% { transform: translate(-50%,-50%) scale(1.1) translate(30px, -20px); }
  }
  .container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .cta-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(36px, 5vw, 64px);
    color: var(--text-primary);
    margin-bottom: 40px;
    line-height: 1.1;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .magnetic-btn { cursor: default; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--accent-cta);
    color: white;
    font-weight: 600;
    font-size: 15px;
    border-radius: 12px;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(249,115,22,0.28);
    transition: transform 200ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 200ms ease;
    animation: glow-pulse 3s ease-in-out infinite;
  }
  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 12px 30px rgba(249,115,22,0.28); }
    50% { box-shadow: 0 16px 40px rgba(249,115,22,0.45); }
  }
  .btn-primary:hover {
    transform: scale(1.02) translateY(-2px);
    box-shadow: 0 16px 40px rgba(249,115,22,0.4);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    background: transparent;
    color: var(--text-primary);
    border: 2px solid var(--border);
    font-weight: 600;
    font-size: 15px;
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .btn-ghost:hover { border-color: var(--accent-primary); color: var(--accent-primary); }

  .divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    color: var(--text-muted);
    font-size: 14px;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Lead magnet */
  .lead-magnet {
    background: var(--bg-surface);
    border-radius: 20px;
    padding: 32px;
    margin-bottom: 40px;
    text-align: left;
  }
  .lm-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  .lm-preview {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
    padding-left: 0;
  }
  .lm-preview li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  .lm-preview li::before {
    content: '✓';
    color: var(--accent-secondary);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .lm-form { margin-top: 0; }
  .lm-input-wrap {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }
  @media (max-width: 540px) { .lm-input-wrap { flex-direction: column; } }
  .input {
    flex: 1;
    padding: 13px 16px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 15px;
    color: var(--text-primary);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .input::placeholder { color: var(--text-muted); }
  .input:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
  }
  .btn-lm {
    padding: 13px 20px;
    background: var(--accent-primary);
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .btn-lm:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(99,102,241,0.25);
  }
  .lm-reassure {
    font-size: 13px;
    color: var(--text-muted);
    text-align: center;
  }

  /* Availability */
  .cta-availability {
    display: flex;
    justify-content: center;
  }
  .avail-items {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: center;
  }
  .avail-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .avail-item strong { color: var(--text-primary); }
  .avail-sep { color: var(--text-muted); }
  .avail-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-secondary);
    border-radius: 50%;
    animation: avail-pulse 2s ease-in-out infinite;
  }
  @keyframes avail-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Scroll reveal */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 600ms cubic-bezier(0.16,1,0.3,1), transform 600ms cubic-bezier(0.16,1,0.3,1);
  }
  .scroll-reveal.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal { opacity: 1; transform: none; transition: none; }
    .blob-light { animation: none; }
    .btn-primary { animation: none; }
  }
</style>

<script>
  // Dynamic availability date — 2 weeks from today
  const nextDate = new Date();
  nextDate.setDate(nextDate.getDate() + 14);
  const month = nextDate.toLocaleString('default', { month: 'long' });
  const day = nextDate.getDate();
  const year = nextDate.getFullYear();
  const availDateEl = document.querySelector('.avail-date-dynamic');
  if (availDateEl) availDateEl.textContent = `${month} ${day}, ${year}`;

  // Magnetic buttons
  document.querySelectorAll('.magnetic-btn').forEach(btn => {
    btn.addEventListener('mousemove', e => {
      const rect = (btn as HTMLElement).getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = e.clientX - cx;
      const dy = e.clientY - cy;
      const dist = Math.sqrt(dx*dx + dy*dy);
      const maxDist = 120;
      const maxMove = 12;
      if (dist < maxDist) {
        const factor = 1 - dist / maxDist;
        (btn as HTMLElement).style.transform = `translate(${dx * factor * (maxMove/maxDist)}px, ${dy * factor * (maxMove/maxDist)}px)`;
      }
    });
    btn.addEventListener('mouseleave', () => {
      (btn as HTMLElement).style.transform = '';
    });
  });

  // Lead magnet form handler
  const lmForm = document.querySelector('.lm-form');
  if (lmForm) {
    lmForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = lmForm.querySelector('.btn-lm');
      const emailInput = lmForm.querySelector('.input') as HTMLInputElement;
      const origText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Sending...';
      try {
        const payload = new FormData();
        payload.append('access_key', '990dbeae-80a7-4bee-87a7-9c3b41d8ba94');
        payload.append('email', emailInput.value);
        payload.append('subject', 'New Lead from Ejago CTA');
        payload.append('from_name', 'Ejago Lead Magnet');
        payload.append('redirect', '');
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: payload
        });
        const json = await res.json();
        if (json.success || res.ok) {
          btn.textContent = '✓ Check your inbox!';
          emailInput.value = '';
          setTimeout(() => {
            btn.disabled = false;
            btn.textContent = origText;
          }, 4000);
        } else {
          throw new Error();
        }
      } catch {
        btn.disabled = false;
        btn.textContent = origText;
        // Fall back to pre-filled mailto
        const subject = encodeURIComponent('Free DTC Growth Audit Request');
        const body = encodeURIComponent(`Hi Ejago team,\n\nI'd like to claim my free DTC Growth Audit.\n\nMy email: ${emailInput.value}`);
        window.location.href = `mailto:info@ejago.com?subject=${subject}&body=${body}`;
      }
    });
  }
</script>
