---
const quickLinks = [
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Work", href: "/work" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Col 1: Navigation -->
      <div class="footer-col">
        <h3 class="col-title">Navigate</h3>
        <ul class="col-links">
          {quickLinks.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <!-- Col 3: Connect -->
      <div class="footer-col">
        <h3 class="col-title">Connect</h3>
        <ul class="col-links contact-links">
          <li>
            <a href="mailto:info@ejago.com">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              info@ejago.com
            </a>
          </li>
          <li>
            <a href="tel:+14242568828">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
              (424) 256-8828
            </a>
          </li>
          <li class="location">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Los Angeles Based, Remote-First
          </li>
        </ul>
      </div>

      <!-- Col 4: AI badge + CTA -->
      <div class="footer-col">
        <div class="ai-badge">
          <div class="ai-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M16 14H8a4 4 0 0 0-4 4v4h16v-4a4 4 0 0 0-4-4z"/><circle cx="9" cy="15" r="1"/><circle cx="15" cy="15" r="1"/><path d="M9 18h6"/></svg>
          </div>
          <div>
            <p class="ai-label">Built by AI agents.</p>
            <p class="ai-sub">Not just humans. We practice what we preach.</p>
          </div>
        </div>
        <a href="/contact" class="footer-cta">
          Get Our Free AI Audit →
        </a>
        <p class="footer-trust">Trusted by DTC brands doing $1M–$50M/yr</p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="copyright">© 2026 Ejago. Results-focused. No fluff.</p>
      <div class="social-links">
        <a href="https://www.linkedin.com/company/ejago" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://www.instagram.com/ejago" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://twitter.com/ejago" aria-label="Twitter">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--text-primary);
    color: rgba(255,255,255,0.7);
    padding: 80px 0 40px;
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
    margin-bottom: 64px;
  }
  @media (max-width: 1024px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .footer-grid { grid-template-columns: 1fr; gap: 32px; } }

  .col-title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: white;
    margin-bottom: 16px;
  }
  .col-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .col-links a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 14px;
    transition: color 200ms ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .col-links a:hover { color: white; }
  .location {
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* AI badge */
  .ai-badge {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .ai-icon {
    width: 40px;
    height: 40px;
    background: rgba(99,102,241,0.3);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #818cf8;
    flex-shrink: 0;
  }
  .ai-label {
    font-weight: 600;
    font-size: 14px;
    color: white;
    margin-bottom: 4px;
  }
  .ai-sub { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.4; }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    font-size: 14px;
    font-weight: 600;
    color: #818cf8;
    text-decoration: none;
    transition: color 200ms ease;
    margin-bottom: 12px;
  }
  .footer-cta:hover { color: white; }

  .footer-trust {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(255,255,255,0.35);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .copyright {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }
  .social-links {
    display: flex;
    gap: 16px;
  }
  .social-links a {
    color: rgba(255,255,255,0.4);
    transition: color 200ms ease;
    display: flex;
    align-items: center;
  }
  .social-links a:hover { color: white; }
</style>
