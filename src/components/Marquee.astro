---
const items = [
  "$47M+ Revenue Moved",
  "64% Conversion Increase", 
  "12M+ Impressions",
  "50+ AI Campaigns",
  "DTC Specialists",
  "AI-Powered",
  "Results Guaranteed",
  "No fluff, just ROI"
];
---

<div class="marquee-container">
  <div class="marquee-content">
    {[...items, ...items, ...items].map(item => (
      <span class="marquee-item">
        {item}
        <span class="separator">✦</span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee-container {
    overflow: hidden;
    background: linear-gradient(90deg, var(--accent-primary), #4f46e5);
    padding: 16px 0;
    position: relative;
  }
  .marquee-content {
    display: flex;
    animation: marquee 30s linear infinite;
    white-space: nowrap;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 0 32px;
    color: white;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
  }
  .separator {
    opacity: 0.5;
  }
</style>
