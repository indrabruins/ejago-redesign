---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ejago — We Build. We Scale. We Automate. | LA Digital Agency",
  description = "Full-stack digital agency in Los Angeles. Websites, apps, AI automation, and performance advertising — one team, one system.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://ejago.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XZ9GQHGR34"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XZ9GQHGR34');
    </script>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://assets.calendly.com https://js.stripe.com; frame-src https://calendly.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://calendly.com;" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0E" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preload" as="image" href="/ejago-hero-v2.png" fetchpriority="high" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Ejago" />
    <meta property="og:image" content="https://ejago.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://ejago.com/og-image.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />

    <title>{title}</title>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      })();

      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      }
    </script>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Ejago",
        "description": "Full-stack digital agency in Los Angeles. Websites, apps, AI automation, and performance advertising.",
        "url": "https://ejago.com",
        "telephone": "+1-323-EJAGO",
        "email": "hello@ejago.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Los Angeles",
          "addressRegion": "CA",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "34.0522",
          "longitude": "-118.2437"
        },
        "openingHours": "Mo-Fr 09:00-18:00",
        "priceRange": "$$",
        "areaServed": "Los Angeles",
        "serviceType": ["Web Development", "Mobile App Development", "AI Automation", "Google Ads", "Meta Ads", "TikTok Ads"]
      }
    </script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What services does Ejago offer?",
      "acceptedAnswer": { "@type": "Answer", "text": "AI automation, custom web development, Google/Meta ads, mobile apps, and custom integrations." }
    },
    {
      "@type": "Question",
      "name": "How much does a project cost?",
           "acceptedAnswer": { "@type": "Answer", "text": "Projects start at $5K for automations, $8K for websites, and $15K+ for custom builds. Free discovery call available." }
    },
    {
      "@type": "Question",
      "name": "How fast can we launch?",
      "acceptedAnswer": { "@type": "Answer", "text": "Typical delivery is 2–6 weeks for full projects. Budget Calculator available." }
    },
    {
      "@type": "Question",
      "name": "Do you work with early-stage startups?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — we work with seed-stage to Series B companies." }
    },
    {
      "@type": "Question",
      "name": "What's your process?",
      "acceptedAnswer": { "@type": "Answer", "text": "Discovery call → Strategy → Design/Build → Launch → Optimize." }
    }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Ejago",
  "url": "https://ejago.com",
  "logo": "https://ejago.com/favicon.svg",
  "sameAs": [
    "https://linkedin.com/company/ejago",
    "https://twitter.com/ejago"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hello@ejago.com",
    "contactType": "customer support"
  }
}
</script>
</head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
