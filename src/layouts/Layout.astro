---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Ejago — We Build Obsession",
  description = "AI-powered marketing for DTC brands who refuse to be forgettable."
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <meta property="og:title" content="Ejago — AI-First Marketing Agency" />
  <meta property="og:description" content="We turn DTC brands into category leaders. $8.5K/mo." />
  <meta property="og:image" content="/assets/og-image.png" />
  <meta property="og:url" content="https://ejago.com" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Ejago — AI-First Marketing Agency" />
  <meta name="twitter:description" content="We turn DTC brands into category leaders." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <!-- Cursor follower -->
  <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
  <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>
  <slot />
  <script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';
  gsap.registerPlugin(ScrollTrigger);

  // ── Lenis smooth scroll ─────────────────────────────────────
  const lenis = new Lenis({ duration: 1.3, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
  function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
  lenis.on('scroll', ScrollTrigger.update);

  // ── Cursor follower ─────────────────────────────────────────
  const dot = document.getElementById('cursor-dot');
  const ring = document.getElementById('cursor-ring');
  let rx = 0, ry = 0, mx = 0, my = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; if (dot) { dot.style.left = mx+'px'; dot.style.top = my+'px'; } });
  function animateRing() {
    rx += (mx - rx) * 0.1; ry += (my - ry) * 0.1;
    if (ring) { ring.style.left = rx+'px'; ring.style.top = ry+'px'; }
    requestAnimationFrame(animateRing);
  }
  animateRing();
  // Expand cursor on interactive elements
  document.querySelectorAll('a, button, input, textarea, select, .magnetic-btn, .btn-primary, .btn-ghost').forEach(el => {
    el.addEventListener('mouseenter', () => ring?.classList.add('expanded'));
    el.addEventListener('mouseleave', () => ring?.classList.remove('expanded'));
  });

  // ── Scroll Reveal ───────────────────────────────────────────
  const scrollObs = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.scroll-reveal').forEach(el => scrollObs.observe(el));

  // ── Counter Animation ────────────────────────────────────────
  const counterObs = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting && !e.target.dataset.done) {
        e.target.dataset.done = 'true';
        const target = e.target.getAttribute('data-count');
        const num = parseInt(target.replace(/[^0-9]/g,''));
        const suffix = target.replace(/[0-9]/g,'');
        let start = null;
        const dur = 1800;
        function step(ts) {
          if (!start) start = ts;
          const p = Math.min((ts-start)/dur, 1);
          const ease = 1-Math.pow(1-p,3);
          e.target.textContent = Math.floor(num*ease)+suffix;
          if (p<1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }
    }),
    { threshold: 0.5 }
  );
  document.querySelectorAll('.counter').forEach(el => counterObs.observe(el));

  // ── Word Scramble (Hero) ─────────────────────────────────────
  function scramble(el) {
    const final = el.dataset.word;
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%';
    let frame = 0, maxF = 18;
    const tick = () => {
      el.textContent = final.split('').map((c,i) => i < (frame/maxF)*final.length ? c : chars[Math.floor(Math.random()*chars.length)]).join('');
      if (frame++ < maxF) requestAnimationFrame(tick); else el.textContent = final;
    };
    tick();
  }
  const words = document.querySelectorAll('.hero-word');
  words.forEach((w,i) => {
    w.style.opacity='1';
    setTimeout(()=>scramble(w), 200+i*150);
  });
  setTimeout(()=>{ document.querySelector('.hero-sub')?.classList.add('visible'); }, 200+words.length*150+200);
  setTimeout(()=>{ document.querySelectorAll('.hero-cta').forEach((b,i)=>setTimeout(()=>b.classList.add('visible'),i*100)); }, 200+words.length*150+500);
  setTimeout(()=>{ document.querySelector('.hero-availability')?.classList.add('visible'); }, 200+words.length*150+700);

  // ── 3D Card Tilt ─────────────────────────────────────────────
  document.querySelectorAll('.card-3d').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const dx = (e.clientX - r.left - r.width/2) / (r.width/2);
      const dy = (e.clientY - r.top  - r.height/2) / (r.height/2);
      card.style.transform = `perspective(800px) rotateY(${dx*8}deg) rotateX(${-dy*8}deg) translateY(-6px) scale(1.02)`;
    });
    card.addEventListener('mouseleave', () => { card.style.transform = ''; });
  });

  // ── Manifesto GSAP Clip-Path Reveal ──────────────────────────
  const mfText = document.querySelector('.manifesto-text');
  if (mfText) {
    gsap.fromTo(mfText,
      { clipPath: 'inset(0 100% 0 0)' },
      { clipPath: 'inset(0 0% 0 0)', duration: 0.9, ease: 'power3.inOut',
        scrollTrigger: { trigger: mfText, start: 'top 80%', once: true } }
    );
  }

  // ── Hero Mouse Parallax ───────────────────────────────────────
  const hero = document.getElementById('hero');
  const vLayer = document.getElementById('hero-video-layer');
  const pWrap  = document.querySelector('.hero-parallax-video-wrap');
  hero?.addEventListener('mousemove', e => {
    const r = hero.getBoundingClientRect();
    const dx = (e.clientX - r.left - r.width/2)  / r.width;
    const dy = (e.clientY - r.top  - r.height/2) / r.height;
    if (pWrap)  pWrap.style.transform  = `translateY(${window.scrollY*0.5}px) translateX(${dx*18}px)`;
    if (vLayer) vLayer.style.transform = `translateY(${window.scrollY*0.3}px) translateX(${dx*8}px)`;
  });

  // ── Services GSAP Stagger ─────────────────────────────────────
  document.querySelectorAll('.service-card').forEach((card, i) => {
    gsap.fromTo(card,
      { opacity: 0, y: 40 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', delay: i*0.1,
        scrollTrigger: { trigger: card, start: 'top 88%', once: true } }
    );
  });

  // ── Process SVG Line Draw ────────────────────────────────────
  const processLine = document.querySelector('.process-line path');
  if (processLine) {
    const len = processLine.getTotalLength?.() || 800;
    gsap.set(processLine, { strokeDasharray: len, strokeDashoffset: len });
    gsap.to(processLine, {
      strokeDashoffset: 0, duration: 2.5, ease: 'power2.inOut',
      scrollTrigger: { trigger: '.process-section', start: 'top 65%', once: true }
    });
  }

  // ── Nav glass on scroll ──────────────────────────────────────
  const nav = document.querySelector('.header');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('nav-glass', window.scrollY > 60);
  }, { passive: true });

  // ── Mobile menu ───────────────────────────────────────────────
  const mBtn = document.getElementById('mobile-menu-btn');
  const mNav = document.getElementById('mobile-nav');
  mBtn?.addEventListener('click', () => {
    mBtn.classList.toggle('open');
    mBtn.setAttribute('aria-expanded', String(mBtn.classList.contains('open')));
    mNav?.classList.toggle('open', mBtn.classList.contains('open'));
  });
</script>
</body>
</html>
<style is:global>
  @import "../styles/global.css";

  /* Cursor follower */
  .cursor-dot {
    position: fixed;
    width: 8px;
    height: 8px;
    background: #6366f1;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: opacity 200ms ease;
  }
  .cursor-ring {
    position: fixed;
    width: 40px;
    height: 40px;
    border: 1.5px solid rgba(99,102,241,0.6);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    opacity: 0.5;
    transition: width 250ms cubic-bezier(0.16,1,0.3,1), height 250ms cubic-bezier(0.16,1,0.3,1), opacity 250ms ease, border-color 250ms ease;
  }
  .cursor-ring.expanded {
    width: 60px;
    height: 60px;
    opacity: 0.8;
    border-color: rgba(249,115,22,0.8);
  }
  @media (hover: none) {
    .cursor-dot, .cursor-ring { display: none !important; }
  }
</style>
