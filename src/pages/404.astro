---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Lost? | Ejago" description="The page you're looking for has drifted off. Let's get you back on track.">
  <div class="min-h-screen flex items-center justify-center relative overflow-hidden" style="background-color: var(--bg);">

    <!-- Animated grid background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(var(--text) 1px, transparent 1px), linear-gradient(90deg, var(--text) 1px, transparent 1px); background-size: 60px 60px;" />

    <!-- Floating decorative orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full" style="background: radial-gradient(circle, var(--accent) 0%, transparent 70%); opacity: 0.06; filter: blur(80px);" />
    <div class="absolute bottom-1/4 right-1/4 w-72 h-72 rounded-full" style="background: radial-gradient(circle, var(--accent) 0%, transparent 70%); opacity: 0.04; filter: blur(60px);" />

    <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
      <!-- 404 with glitch effect -->
      <div class="mb-8 relative">
        <span
          class="text-[10rem] md:text-[14rem] font-black leading-none block"
          style="font-family: var(--font-display); color: var(--accent); text-shadow: 0 0 60px rgba(124, 58, 237, 0.3);"
        >404</span>
        <!-- Decorative line under number -->
        <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-48 h-px" style="background: linear-gradient(90deg, transparent, var(--border), transparent);" />
      </div>

      <!-- Hook headline -->
      <h1 class="text-3xl md:text-5xl font-bold mb-4" style="font-family: var(--font-display); color: var(--text);">
        You drifted off course.
      </h1>

      <!-- Supportive copy -->
      <p class="text-lg md:text-xl mb-8" style="color: var(--text-secondary); line-height: 1.7;">
        The page you're looking for has moved, doesn't exist, or was maybe never here.<br class="hidden md:block" />
        Either way — let's get you back to growing.
      </p>

      <!-- Quick navigation cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        <a
          href="/"
          class="group p-6 rounded-2xl border transition-all duration-300 hover:scale-[1.03]"
          style="background: var(--surface); border-color: var(--border);"
        >
          <div class="text-2xl mb-2" style="color: var(--accent);">⌂</div>
          <div class="font-semibold mb-1" style="color: var(--text);">Homepage</div>
          <div class="text-sm" style="color: var(--text-secondary);">Where it all starts</div>
        </a>
        <a
          href="/#contact"
          class="group p-6 rounded-2xl border transition-all duration-300 hover:scale-[1.03]"
          style="background: var(--surface); border-color: var(--border);"
        >
          <div class="text-2xl mb-2" style="color: var(--accent);">✉</div>
          <div class="font-semibold mb-1" style="color: var(--text);">Contact Us</div>
          <div class="text-sm" style="color: var(--text-secondary);">Start a conversation</div>
        </a>
        <a
          href="/work"
          class="group p-6 rounded-2xl border transition-all duration-300 hover:scale-[1.03]"
          style="background: var(--surface); border-color: var(--border);"
        >
          <div class="text-2xl mb-2" style="color: var(--accent);">◈</div>
          <div class="font-semibold mb-1" style="color: var(--text);">Our Work</div>
          <div class="text-sm" style="color: var(--text-secondary);">See the results</div>
        </a>
      </div>

      <!-- CTA -->
      <div class="mb-6">
        <p class="text-sm mb-4" style="color: var(--text-secondary);">
          Or start building right now — book a free strategy call in 30 seconds.
        </p>
        <a
          href="https://calendly.com/indra-ejago"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg transition-all hover:scale-[1.03]"
          style="background: var(--accent); color: white;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Book a Free Strategy Call →
        </a>
      </div>

      <!-- Search hint -->
      <p class="text-sm" style="color: var(--text-secondary); opacity: 0.6;">
        If you have a specific page in mind, try the navigation above or
        <a href="/" class="underline" style="color: var(--accent);">return home</a>.
      </p>
    </div>
  </div>
</Layout>