---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import BigFooterCTA from '../components/BigFooterCTA';
---

<Layout title="Blog | Ejago" description="Insights, tutorials, and updates from the Ejago team.">
  <Header client:load />
  <main class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Blog</h1>
      <p class="text-xl text-gray-600 mb-8">Insights, tutorials, and updates coming soon.</p>
      
      <div class="grid gap-6">
        <div class="p-6 border border-gray-200 rounded-lg">
          <p class="text-sm text-gray-500 mb-2">Coming Soon</p>
          <h2 class="text-2xl font-semibold mb-2">Blog posts will appear here</h2>
          <p class="text-gray-600">We're working on valuable content for you. Check back soon!</p>
        </div>
      </div>
    </div>
  </main>
  <BigFooterCTA client:load />
  <Footer client:load />
</Layout>
