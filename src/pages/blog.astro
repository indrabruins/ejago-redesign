---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import BigFooterCTA from '../components/BigFooterCTA';

const posts = [
  {
    title: "The True Cost of Bad Marketing: Why Most Agencies Overcharge and Underdeliver",
    category: "Strategy",
    date: "Apr 8, 2026",
    excerpt: "Most businesses spend $30K-$100K/year on agencies that deliver inconsistent results. Here's the math on what that actually costs you — and how to build a system that compounds.",
    readTime: "8 min read",
    href: "/#contact"
  },
  {
    title: "How AI Chatbots Are Replacing 60% of Lead Intake (And Why That's a Good Thing)",
    category: "AI Automation",
    date: "Mar 25, 2026",
    excerpt: "Your sales team is spending 40% of their time answering the same 10 questions. An AI chatbot handles that 24/7 — and routes the right leads to the right humans. Here's the playbook we used for 12 clients.",
    readTime: "6 min read",
    href: "/#contact"
  },
  {
    title: "LA Benchmarks: What $10K/Month in Ad Spend Actually Gets You in Los Angeles",
    category: "Advertising",
    date: "Mar 10, 2026",
    excerpt: "We analyzed 23 LA-based campaigns across e-commerce, local services, and B2B. The data is surprising: most businesses are leaving 2-3x ROAS on the table simply due to targeting and creative misalignment.",
    readTime: "10 min read",
    href: "/#contact"
  }
];
---

<Layout title="Blog | Ejago" description="Insights on AI automation, performance advertising, and growth strategy from the Ejago team in Los Angeles.">
  <Header client:load />
  <main style="background-color: var(--bg); min-height: 100vh;">
    <div class="max-w-[85vw] mx-auto px-6 py-20 md:py-28">
      <!-- Header -->
      <div class="mb-16 max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-widest mb-3" style="color: var(--accent);">Insights</p>
        <h1 class="text-5xl md:text-6xl font-bold mb-5" style="font-family: var(--font-display); color: var(--text);">
          The Ejago Blog
        </h1>
        <p class="text-lg md:text-xl" style="color: var(--text-secondary);">
          Strategy, automation, and growth intelligence for ambitious businesses in Los Angeles and beyond.
        </p>
      </div>

      <!-- Posts grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a
            href={post.href}
            class="group block rounded-2xl overflow-hidden border transition-all duration-300 hover:scale-[1.02] hover:shadow-xl"
            style="background-color: var(--surface); border-color: var(--border);"
          >
            <!-- Category badge -->
            <div class="px-6 pt-6 pb-2">
              <span
                class="inline-block text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full"
                style="background-color: var(--accent); color: white;"
              >
                {post.category}
              </span>
            </div>
            <!-- Content -->
            <div class="px-6 pb-6">
              <p class="text-sm mb-3" style="color: var(--text-secondary);">{post.date} · {post.readTime}</p>
              <h2 class="text-xl font-bold mb-3 group-hover:opacity-80 transition-opacity" style="font-family: var(--font-display); color: var(--text);">
                {post.title}
              </h2>
              <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
                {post.excerpt}
              </p>
            </div>
            <!-- CTA -->
            <div class="px-6 pb-6">
              <span class="inline-flex items-center gap-2 text-sm font-semibold" style="color: var(--accent);">
                Get the full breakdown →
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Newsletter CTA -->
      <div
        class="mt-20 p-10 md:p-14 rounded-3xl text-center border"
        style="background-color: var(--surface-alt); border-color: var(--border);"
      >
        <h2 class="text-2xl md:text-3xl font-bold mb-4" style="font-family: var(--font-display); color: var(--text);">
          Want growth insights in your inbox?
        </h2>
        <p class="text-lg mb-8 max-w-xl mx-auto" style="color: var(--text-secondary);">
          No spam. No fluff. Just actionable strategy from a team that's generated $100M+ in revenue for clients.
        </p>
        <a
          href="/#contact"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg transition-all hover:scale-[1.03]"
          style="background: var(--accent); color: white;"
        >
          Talk to Our Team →
        </a>
      </div>
    </div>
  </main>
  <BigFooterCTA client:load />
  <Footer client:load />
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Blog","name":"Ejago Blog — Insights on AI, Advertising & Growth","description":"Insights and updates from the Ejago team on AI automation, performance advertising, and digital growth.","url":"https://ejago.com/blog","publisher":{"@type":"Organization","name":"Ejago","url":"https://ejago.com"}}</script>
</Layout>
