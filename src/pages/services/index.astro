---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import BackToTop from '../../components/BackToTop';

const services = [
  {
    title: "Website Development",
    href: "/services/website-development",
    icon: "🌐",
    color: "#7C3AED",
    tagline: "Products, Not Brochures.",
    desc: "Custom websites, e-commerce, and web apps designed to convert. Every line of code serves a purpose."
  },
  {
    title: "Mobile Apps",
    href: "/services/mobile-apps",
    icon: "📱",
    color: "#3B82F6",
    tagline: "In Their Pocket.",
    desc: "iOS and Android apps that people keep on their home screen. Native feel, cross-platform speed."
  },
  {
    title: "Custom Integrations",
    href: "/services/custom-integrations",
    icon: "🔌",
    color: "#A855F7",
    tagline: "One System, Not 12.",
    desc: "Connect your entire tech stack — CRM, payments, marketing, inventory — so your business runs on autopilot."
  },
  {
    title: "AI Automation",
    href: "/services/ai-automation",
    icon: "🧠",
    color: "#10B981",
    tagline: "Work That Kills Momentum.",
    desc: "Multi-agent AI systems that handle customer service, lead qualification, and document processing — 24/7."
  },
  {
    title: "Google Ads",
    href: "/services/google-ads",
    icon: "🔍",
    color: "#EF4444",
    tagline: "Every Dollar. Tracked.",
    desc: "AI-optimized Search, Display, YouTube, and Shopping campaigns. Performance Max with human oversight."
  },
  {
    title: "Meta & TikTok Ads",
    href: "/services/meta-tiktok-ads",
    icon: "📱",
    color: "#EC4899",
    tagline: "Stop Paying to Not Convert.",
    desc: "Scroll-stopping video creative + precision audiences + AI optimization. Full-funnel social advertising."
  },
];
---

<Layout
  title="Services — Ejago | Full-Stack Digital Agency"
  description="Full-stack digital services: websites, mobile apps, AI automation, custom integrations, Google Ads, and Meta/TikTok advertising."
>
  <Header client:load />

  <!-- Hero -->
  <section class="min-h-[60vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full blur-3xl"
           style="background: radial-gradient(circle, rgba(124,58,237,0.2) 0%, transparent 70%);" />
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full blur-3xl"
           style="background: radial-gradient(circle, rgba(245,158,11,0.15) 0%, transparent 70%);" />
    </div>
    <div class="relative z-10 max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 w-full text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6"
           style="background-color: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.25);">
        <span class="text-sm font-medium" style="color: #7C3AED;">Full-Stack Digital Agency</span>
      </div>
      <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight" style="font-family: var(--font-display); color: var(--text);">
        Everything Your Business<br/>
        <span style="color: #7C3AED;">Needs to Grow.</span>
      </h1>
      <p class="text-lg md:text-xl max-w-2xl mx-auto" style="color: var(--text-secondary); line-height: 1.7;">
        Six core services. One integrated team. We don't hand off projects — we own outcomes from strategy to scale.
      </p>
    </div>
  </section>

  <!-- All Services Grid -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={s.href}
             class="group p-8 rounded-2xl relative overflow-hidden block"
             style="background-color: var(--surface); border: 1px solid var(--border); transition: all 0.3s ease;">
            <!-- Hover glow -->
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                 style={`background: linear-gradient(135deg, ${s.color}18, transparent 60%); border: 1px solid ${s.color}40;`} />

            <div class="relative z-10">
              <div class="text-4xl mb-6">{s.icon}</div>
              <h2 class="text-xl font-bold mb-2" style="font-family: var(--font-display); color: var(--text);">
                {s.title}
              </h2>
              <p class="text-sm font-medium mb-3" style={`color: ${s.color};`}>
                "{s.tagline}"
              </p>
              <p class="text-sm mb-6" style="color: var(--text-secondary); line-height: 1.7;">
                {s.desc}
              </p>
              <div class="flex items-center gap-2 text-sm font-medium" style={`color: ${s.color};`}>
                Learn more
                <span class="group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why one agency -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #7C3AED;">Why One Agency</p>
          <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: var(--text);">
            Six Services.<br/>One System.
          </h2>
          <p class="text-base mb-6" style="color: var(--text-secondary); line-height: 1.8;">
            Most agencies sell you one service and blame the others when results don't come. We build integrated systems — your website talks to your CRM, your ads feed your automation, your analytics inform your creative. Every piece amplifies the others.
          </p>
          <p class="text-base" style="color: var(--text-secondary); line-height: 1.8;">
            One team. One Slack channel. One quarterly review. Maximum compounding growth instead of siloed tactics that cancel each other out.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { from: "Google Ads", to: "CRM", result: "Leads auto-qualified and routed" },
            { from: "Website", to: "Email", result: "Abandoned carts recovered automatically" },
            { from: "Meta Ads", to: "AI Agent", result: "Hot leads get a call within 2 minutes" },
            { from: "Analytics", to: "Creative", result: "Ads optimized based on real conversion data" },
          ].map(item => (
            <div class="flex items-center gap-4 p-4 rounded-xl" style="background-color: var(--bg); border: 1px solid var(--border);">
              <span class="text-sm font-semibold px-3 py-1 rounded-full" style="background-color: rgba(124,58,237,0.1); color: #7C3AED;">{item.from}</span>
              <span class="text-xl" style="color: var(--text-secondary);">→</span>
              <span class="text-sm font-semibold px-3 py-1 rounded-full" style="background-color: rgba(124,58,237,0.1); color: #7C3AED;">{item.to}</span>
              <span class="text-sm" style="color: var(--text-secondary);">= {item.result}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32" style="background-color: #7C3AED;">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 text-center">
      <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">
        Not Sure Where to Start?
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);">
        Book a free 30-minute strategy call. We'll audit your current setup and tell you exactly which service would move the needle fastest for your business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: white; color: #7C3AED;">Book a Strategy Call →</a>
        <a href="/" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: transparent; color: white; border: 2px solid white;">Back to Home →</a>
      </div>
    </div>
  </section>

  <Footer client:load />
  <BackToTop client:load />
</Layout>
