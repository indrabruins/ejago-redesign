---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import BigFooterCTA from '../../components/BigFooterCTA';
import ContactSection from '../../components/ContactSection';
import BackToTop from '../../components/BackToTop';

const integrations = [
  { title: "CRM Connections", desc: "Connect HubSpot, Salesforce, Pipedrive, or any CRM to your website, ads, and email — so nothing falls through the cracks." },
  { title: "Payment Processing", desc: "Stripe, Square, PayPal — integrated cleanly so your transactions flow into your dashboard automatically." },
  { title: "Marketing Automation", desc: "Connect Klaviyo, Mailchimp, ActiveCampaign to your store or CRM for automated nurture sequences." },
  { title: "Inventory & ERP", desc: "Sync stock levels, purchase orders, and supplier data across all your channels in real time." },
  { title: "Custom API Development", desc: "We build the bridge when a native integration doesn't exist. Any two systems can talk to each other." },
  { title: "Webhooks & Events", desc: "Real-time event-driven architecture — when something happens in one system, everything else responds instantly." },
];

const process = [
  { step: "01", title: "Map the Stack", desc: "We audit every tool you use and identify every manual handoff. That becomes our integration checklist." },
  { step: "02", title: "Build the Bridges", desc: "We build custom connectors, webhooks, and middleware — no duct tape, no Zapier workarounds that break." },
  { step: "03", title: "Test Under Load", desc: "We simulate real-world data volume and stress-test every connection before go-live." },
  { step: "04", title: "Monitor & Maintain", desc: "We set up alerts and dashboards so you see the health of your entire tech stack in one place." },
];
---

<Layout
  title="Custom Integrations — Ejago | CRM, API, Zapier, Marketing Automation Integrations"
  description="Custom integrations that connect your entire tech stack. We build the bridges between your tools so your business runs on autopilot."
>
  <Header client:load />

  <!-- Hero -->
  <section class="min-h-[70vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full blur-3xl animate-mesh-1"
           style="background: radial-gradient(circle, rgba(168,85,247,0.3) 0%, transparent 70%);" />
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full blur-3xl animate-mesh-3"
           style="background: radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);" />
    </div>
    <div class="relative z-10 max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6"
             style="background-color: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.25);">
          <span class="text-sm font-medium" style="color: #A855F7;">🔌 Custom Integrations</span>
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight" style="font-family: var(--font-display); color: var(--text);">
          One System.<br/>
          <span style="color: #A855F7);">Not 12 of Them.</span>
        </h1>
        <p class="text-lg md:text-xl" style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
          Your tools shouldn't need a human to talk to each other. We build custom integrations that connect your CRM, ads, payments, email, and analytics — so your business operates on signals, not manual updates.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-10">
          <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
             style="background-color: #A855F7; color: white;">
            Connect My Stack →
          </a>
          <a href="https://calendly.com/indra-ejago" target="_blank"
             class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
             style="background-color: transparent; color: var(--text); border: 2px solid var(--border);">
            Book a Call →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 border-y" style="border-color: var(--border); background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { n: "200+", l: "Integrations Built" },
          { n: "100+", l: "API Connections" },
          { n: "0", l: "Manual Data Entry (For Clients)" },
          { n: "99.9%", l: "Integration Uptime" },
        ].map(s => (
          <div>
            <div class="text-3xl md:text-4xl font-bold mb-1" style="font-family: var(--font-mono); color: #A855F7;">{s.n}</div>
            <div class="text-sm" style="color: var(--text-secondary);">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #A855F7;">What We Connect</p>
        <h2 class="text-3xl md:text-5xl mb-4" style="font-family: var(--font-display); color: var(--text);">
          Your Stack, Finally Talking
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
          We don't believe in "it should work with Zapier." We build connections that are fast, reliable, and owned by you — not by a third-party automation platform that changes pricing overnight.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {integrations.map(i => (
          <div class="p-8 rounded-2xl" style="background-color: var(--surface); border: 1px solid var(--border);">
            <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{i.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">{i.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #A855F7;">Our Process</p>
        <h2 class="text-3xl md:text-5xl mb-4" style="font-family: var(--font-display); color: var(--text);">
          Built Once. Runs Forever.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map(p => (
          <div>
            <div class="text-5xl font-bold mb-4" style="font-family: var(--font-display); color: rgba(168,85,247,0.2);">{p.step}</div>
            <h3 class="text-xl font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{p.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.7;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #A855F7;">FAQ</p>
          <h2 class="text-3xl md:text-5xl" style="font-family: var(--font-display); color: var(--text);">Integration Questions</h2>
        </div>
        <div class="space-y-6">
          {[
            { q: "Why not just use Zapier?", a: "Zapier is great for simple automations. But when you need speed, volume, and reliability — custom integrations win. Our connections run at API speed (not Zapier's polling intervals), handle errors gracefully, and don't break when Zapier changes their plan pricing." },
            { q: "What if we need an integration that doesn't exist?", a: "We've built custom API connectors for tools that have no native integration. If an API exists, we can build a bridge to it. We've never found a system we couldn't connect." },
            { q: "Who owns the integration code?", a: "You do. We build on your infrastructure, use your API keys, and deliver the code. No lock-in, no proprietary middleware you can't escape." },
            { q: "How long does a typical integration take?", a: "A standard CRM-to-website integration takes 1-2 weeks. Complex multi-system pipelines (e.g., ERP + CRM + Marketing + BI) take 4-8 weeks. We scope everything before we start." },
          ].map(f => (
            <details class="p-6 rounded-xl" style="background-color: var(--surface); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between cursor-pointer list-none font-semibold" style="color: var(--text);">
                {f.q}
                <span style="color: #A855F7;">+</span>
              </summary>
              <p class="mt-4 text-sm" style="color: var(--text-secondary); line-height: 1.7;">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32" style="background-color: #A855F7;">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 text-center">
      <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">
        Stop Exporting CSVs.
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);">
        Tell us your current workflow — every tool, every manual step. We'll show you exactly how we'd automate it.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: white; color: #A855F7;">Audit My Stack →</a>
        <a href="/services" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: transparent; color: white; border: 2px solid white;">See All Services →</a>
      </div>
    </div>
  </section>

  <BigFooterCTA client:load />
  <ContactSection client:load />
  <Footer client:load />
  <BackToTop client:load />
</Layout>
