---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import BackToTop from '../../components/BackToTop';

const offerings = [
  { title: "Search Campaigns", desc: "Capture high-intent traffic the moment someone searches for what you offer." },
  { title: "Performance Max", desc: "AI-optimized cross-channel campaigns that find converts across YouTube, Gmail, and Display." },
  { title: "Display Advertising", desc: "Build brand awareness with precision-targeted display across Google's 35M+ sites." },
  { title: "YouTube Ads", desc: "Skippable, non-skippable, and in-feed — from awareness to direct response." },
  { title: "Shopping Campaigns", desc: "Product feed optimization for e-commerce brands with real-time bid management." },
  { title: "Remarketing", desc: "Bring back every visitor who didn't convert — with tailored offers and messaging." },
];
---

<Layout
  title="Google Ads Management — Ejago | AI-Optimized Google Ads, Performance Max, PPC"
  description="AI-powered Google Ads management. Performance Max, Search, Display, YouTube, and Shopping campaigns optimized in real time by humans + AI."
>
  <Header client:load />

  <!-- Hero -->
  <section class="min-h-[70vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full blur-3xl animate-mesh-1"
           style="background: radial-gradient(circle, rgba(239,68,68,0.25) 0%, transparent 70%);" />
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full blur-3xl animate-mesh-3"
           style="background: radial-gradient(circle, rgba(124,58,237,0.2) 0%, transparent 70%);" />
    </div>
    <div class="relative z-10 max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6"
             style="background-color: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.25);">
          <span class="text-sm font-medium" style="color: #EF4444;">🔍 Google Ads</span>
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight" style="font-family: var(--font-display); color: var(--text);">
          Every Dollar.<br/>
          <span style="color: #EF4444;">Tracked. Tested. Optimized.</span>
        </h1>
        <p class="text-lg md:text-xl" style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
          We don't manage Google Ads with spreadsheets and gut instinct. We use AI-powered audience modeling, automated creative testing, and real-time bid optimization to turn your ad spend into compounding revenue — not wasted impressions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-10">
          <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
             style="background-color: #EF4444; color: white;">Grow My Ad Revenue →</a>
          <a href="https://calendly.com/indra-ejago" target="_blank"
             class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
             style="background-color: transparent; color: var(--text); border: 2px solid var(--border);">Book a Call →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 border-y" style="border-color: var(--border); background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { n: "240%", l: "Peak ROAS Achieved" },
          { n: "42%", l: "Avg. Reduction in CPL" },
          { n: "$8M+", l: "Ad Spend Managed" },
          { n: "Weekly", l: "Performance Reports" },
        ].map(s => (
          <div>
            <div class="text-3xl md:text-4xl font-bold mb-1" style="font-family: var(--font-mono); color: #EF4444;">{s.n}</div>
            <div class="text-sm" style="color: var(--text-secondary);">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What we offer -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #EF4444;">What We Manage</p>
        <h2 class="text-3xl md:text-5xl mb-4" style="font-family: var(--font-display); color: var(--text);">
          The Full Google Ads Stack
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
          Every campaign type, every bidding strategy, every audience layer — managed by humans who know what they're doing and AI that works while they sleep.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {offerings.map(o => (
          <div class="p-8 rounded-2xl" style="background-color: var(--surface); border: 1px solid var(--border);">
            <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{o.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">{o.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our approach -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #EF4444;">Our Approach</p>
          <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: var(--text);">
            Why AI + Human = Better Ads
          </h2>
          <div class="space-y-6" style="color: var(--text-secondary); line-height: 1.8;">
            <p><strong style="color: var(--text);">The old way:</strong> A media buyer checks performance on Monday, adjusts bids on Tuesday, and wonders why the campaign drifted by Wednesday.</p>
            <p><strong style="color: var(--text);">Our way:</strong> AI monitors every auction, every impression, every conversion — in real time. When performance shifts, the system adapts immediately. Humans focus on strategy, creative direction, and complex optimization that requires judgment.</p>
            <p><strong style="color: var(--text);">The result:</strong> Campaigns that get smarter over time, not just maintained. Clients typically see a 30-50% improvement in ROAS within 60 days of onboarding.</p>
          </div>
        </div>
        <div class="space-y-4">
          {[
            { title: "Week 1-2: Audit & Setup", desc: "Full audit of existing account. Fix结构和账户问题. Set up tracking, audiences, and conversion events." },
            { title: "Week 3-4: Foundation", desc: "Launch baseline campaigns. Begin collecting first-party data. A/B test creative at scale." },
            { title: "Month 2: AI Optimization", desc: "Activate AI bidding models. Shift budget toward winning campaigns. Scale what works." },
            { title: "Month 3+: Compound", desc: "Remarketing loops, lookalike audiences, and creative refresh. ROAS compounds over time." },
          ].map(m => (
            <div class="flex gap-4 p-4 rounded-xl" style="background-color: var(--bg); border: 1px solid var(--border);">
              <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center text-sm font-bold" style="background-color: #EF4444; color: white;">{m.title.split(':')[0]}</div>
              <div>
                <h4 class="font-semibold mb-1" style="color: var(--text);">{m.title}</h4>
                <p class="text-sm" style="color: var(--text-secondary);">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32" style="background-color: #EF4444;">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 text-center">
      <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">
        Stop Guessing. Start Compounding.
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);">
        Get a free Google Ads audit. We'll show you exactly where your budget is going and what we'd change — no commitment required.
      </p>
      <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
         style="background-color: white; color: #EF4444;">Get My Free Audit →</a>
    </div>
  </section>

  <Footer client:load />
  <BackToTop client:load />
</Layout>