---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import BigFooterCTA from '../../components/BigFooterCTA';
import ContactSection from '../../components/ContactSection';
import BackToTop from '../../components/BackToTop';

const offerings = [
  { title: "Facebook & Instagram Ads", desc: "Feed, Stories, Reels, and Messenger — campaigns across every Meta surface that drives real business outcomes." },
  { title: "TikTok Ads", desc: "In-feed, branded lens, and TopView campaigns that capture attention in the first 0.5 seconds." },
  { title: "Audience Strategy", desc: "Custom audiences, lookalike modeling, and interest targeting refined by real conversion data — not guesswork." },
  { title: "Creative Production", desc: "We write, shoot, and edit video ads optimized for each platform's native format and algorithm." },
  { title: "Retargeting Funnels", desc: "Multi-step retargeting sequences that convert window shoppers into buyers — from cold to warm to hot." },
  { title: "Influencer Amplification", desc: "We take your best organic content and amplify it with paid distribution to 10x its reach." },
];

const process = [
  { step: "01", title: "Audit", desc: "We review your current Meta/TikTok setup — what's working, what's burning budget, and who your real customer is." },
  { step: "02", title: "Strategy", desc: "We define the audience strategy, funnel architecture, and creative brief — all grounded in your customer data." },
  { step: "03", title: "Creative", desc: "We produce video ads that don't look like ads — native, engaging, and built to stop the scroll." },
  { step: "04", title: "Optimize", desc: "AI-driven creative testing + audience optimization. We kill what's failing in 48 hours and scale what works." },
];
---

<Layout
  title="Meta & TikTok Ads — Ejago | Facebook, Instagram, TikTok Advertising"
  description="AI-optimized Meta and TikTok advertising. We create scroll-stopping video ads and manage campaigns that turn attention into revenue."
>
  <Header client:load />

  <!-- Hero -->
  <section class="min-h-[70vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full blur-3xl animate-mesh-1"
           style="background: radial-gradient(circle, rgba(236,72,153,0.3) 0%, transparent 70%);" />
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full blur-3xl animate-mesh-3"
           style="background: radial-gradient(circle, rgba(124,58,237,0.25) 0%, transparent 70%);" />
    </div>
    <div class="relative z-10 max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6"
             style="background-color: rgba(236,72,153,0.12); border: 1px solid rgba(236,72,153,0.25);">
          <span class="text-sm font-medium" style="color: #EC4899;">📱 Meta & TikTok Ads</span>
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight" style="font-family: var(--font-display); color: var(--text);">
          Stop Paying to<br/>
          <span style="color: #EC4899;">Not Convert.</span>
        </h1>
        <p class="text-lg md:text-xl" style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
          Most brands waste 60% of their Meta and TikTok budget on ads that get watched but never clicked. We fix that — with creative that actually stops the scroll, audiences built on real data, and AI that optimizes every dollar in real time.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-10">
          <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
             style="background-color: #EC4899; color: white;">
            Scale My Revenue →
          </a>
          <a href="https://calendly.com/indra-ejago" target="_blank"
             class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
             style="background-color: transparent; color: var(--text); border: 2px solid var(--border);">
            Book a Call →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 border-y" style="border-color: var(--border); background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { n: "180%", l: "Avg. Increase in ROAS" },
          { n: "3.2x", l: "Video Ad CTR vs. Static" },
          { n: "$2.4M", l: "Ad Spend Managed Monthly" },
          { n: "48hrs", l: "Time to First Optimization" },
        ].map(s => (
          <div>
            <div class="text-3xl md:text-4xl font-bold mb-1" style="font-family: var(--font-mono); color: #EC4899;">{s.n}</div>
            <div class="text-sm" style="color: var(--text-secondary);">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Offerings -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #EC4899;">What We Do</p>
        <h2 class="text-3xl md:text-5xl mb-4" style="font-family: var(--font-display); color: var(--text);">
          Scroll-Stopping. Revenue-Generating.
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
          We don't just run ads. We build full-funnel social advertising systems — from the creative that stops the scroll, to the retargeting that closes the sale.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {offerings.map(o => (
          <div class="p-8 rounded-2xl" style="background-color: var(--surface); border: 1px solid var(--border);">
            <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{o.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">{o.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Creative angle -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #EC4899;">Creative</p>
          <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: var(--text);">
            Ads That Don't Look Like Ads
          </h2>
          <div class="space-y-6" style="color: var(--text-secondary); line-height: 1.8;">
            <p>On TikTok and Meta, the audience has one finger ready to scroll past anything that feels like marketing. We create content that earns attention — because it's funny, relatable, educational, or emotionally resonant.</p>
            <p>Then we combine that creative with precision audience targeting and AI optimization, so the right people see the right ad at the right moment in their buying journey.</p>
            <p>The result: creative that gets watched, audiences that convert, and campaigns that scale profitably — not just spend that scales.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { label: "Hook (0-3s)", icon: "⏱️", desc: "Stop the scroll immediately" },
            { label: "Story (3-15s)", icon: "📖", desc: "Build emotional connection" },
            { label: "CTA (15-30s)", icon: "👉", desc: "Clear, compelling action" },
            { label: "Optimize", icon: "🤖", desc: "AI tests 20 variants per week" },
          ].map(item => (
            <div class="p-6 rounded-xl" style="background-color: var(--bg); border: 1px solid var(--border);">
              <div class="text-2xl mb-3">{item.icon}</div>
              <div class="font-bold mb-2" style="color: var(--text);">{item.label}</div>
              <p class="text-sm" style="color: var(--text-secondary);">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #EC4899;">Process</p>
        <h2 class="text-3xl md:text-5xl mb-4" style="font-family: var(--font-display); color: var(--text);">
          From Cold Audience to Hot Revenue
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map(p => (
          <div>
            <div class="text-5xl font-bold mb-4" style="font-family: var(--font-display); color: rgba(236,72,153,0.2);">{p.step}</div>
            <h3 class="text-xl font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{p.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.7;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: #EC4899;">FAQ</p>
          <h2 class="text-3xl md:text-5xl" style="font-family: var(--font-display); color: var(--text);">Social Ads Questions</h2>
        </div>
        <div class="space-y-6">
          {[
            { q: "What's a realistic ROAS expectation?", a: "It depends on your product and margin, but our clients typically see 2-4x ROAS within 60 days. E-commerce brands with strong product-market fit often hit 3-5x. We set honest expectations upfront based on your specific category data." },
            { q: "Do you produce the ad creative?", a: "Yes — and it matters. We produce video ads optimized for each platform's algorithm (TikTok vs. Reels vs. Stories each behave differently). We don't just boost existing content — we create platform-native creative specifically for paid distribution." },
            { q: "What's your minimum ad spend?", a: "We work with brands spending $3,000/month or more on paid social. Below that threshold, the data volume isn't enough for meaningful AI optimization. If you're starting fresh, we'll help you build up to that level." },
            { q: "TikTok or Meta — which should I start with?", a: "It depends on your audience. TikTok skews younger (18-34) and works exceptionally for awareness and e-commerce. Meta (FB + IG) covers all demographics and is superior for B2B, higher ticket items, and retargeting. We recommend both, but we help you prioritize based on where your customers actually live." },
          ].map(f => (
            <details class="p-6 rounded-xl" style="background-color: var(--bg); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between cursor-pointer list-none font-semibold" style="color: var(--text);">
                {f.q}
                <span style="color: #EC4899;">+</span>
              </summary>
              <p class="mt-4 text-sm" style="color: var(--text-secondary); line-height: 1.7;">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32" style="background-color: #EC4899;">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 text-center">
      <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">
        Your Competitors Are Already Here.
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);">
        Get a free social ads audit. We'll review your current campaigns and show you exactly what's costing you money — and what we'd change.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: white; color: #EC4899;">Get My Free Audit →</a>
        <a href="/services" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: transparent; color: white; border: 2px solid white;">See All Services →</a>
      </div>
    </div>
  </section>

  <BigFooterCTA client:load />
  <ContactSection client:load />
  <Footer client:load />
  <BackToTop client:load />
</Layout>
