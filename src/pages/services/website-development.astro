---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import BigFooterCTA from '../../components/BigFooterCTA';
import ContactSection from '../../components/ContactSection';
import BackToTop from '../../components/BackToTop';
---
<Layout title="Website Development — Ejago | Custom Websites, E-commerce, Web Apps" description="Custom website development that converts. We build websites, e-commerce stores, and web applications — designed to perform, not just exist.">
<Header client:load />
<section class="min-h-[70vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full blur-3xl animate-mesh-1" style="background: radial-gradient(circle, rgba(124,58,237,0.3) 0%, transparent 70%);" />
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full blur-3xl animate-mesh-3" style="background: radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);" />
  </div>
  <div class="relative z-10 max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 w-full">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6" style="background-color: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.25);">
        <span class="text-sm font-medium" style="color: #7C3AED;">🌐 Website Development</span>
      </div>
      <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight" style="font-family: var(--font-display); color: var(--text);">
        Products,<br/><span style="color: #7C3AED;">Not Brochures.</span>
      </h1>
      <p class="text-lg md:text-xl" style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
        We build websites that are designed to convert from day one. Every line of code, every component, every animation serves one purpose: turning visitors into customers.
      </p>
    </div>
  </div>
</section>
<section class="py-20 md:py-28" style="background-color: var(--surface);">
  <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { title: "Custom Websites", desc: "From landing pages to multi-page marketing sites — every one optimized for conversion." },
        { title: "E-commerce", desc: "Shopify, WooCommerce, or custom — stores that actually sell, not just display." },
        { title: "Web Applications", desc: "SaaS dashboards, internal tools, and customer portals built to scale." },
        { title: "Progressive Web Apps", desc: "App-like experiences that load fast, work offline, and live on the home screen." },
        { title: "CMS Integration", desc: "Content management systems your team can actually use — WordPress, Sanity, Webflow." },
        { title: "API & Integrations", desc: "Connect your website to every tool in your stack — CRM, analytics, payments, more." },
      ].map(item => (
        <div class="p-8 rounded-2xl" style="background-color: var(--bg); border: 1px solid var(--border);">
          <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{item.title}</h3>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
<section class="py-24 md:py-32" style="background-color: #7C3AED;">
  <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 text-center">
    <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">Ready to Build?</h2>
    <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);">Tell us what you're building. We'll design and build it in 7 days — guaranteed.</p>
    <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg" style="background-color: white; color: #7C3AED;">Start a Project →</a>
  </div>
</section>
<Footer client:load />
<BackToTop client:load />
<script type="application/ld+json">{"@context": "https://schema.org", "@type": "Service", "name": "Website Development", "description": "Custom website development from landing pages to full e-commerce platforms. Built to convert visitors into customers.", "provider": {"@type": "Organization", "name": "Ejago"}, "areaServed": "Worldwide", "url": "https://ejago.com/services/website-development"}</script>
</Layout>
