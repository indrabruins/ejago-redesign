---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import BackToTop from '../components/BackToTop';

const team = [
  {
    name: "Indra Widjaja",
    role: "Co-Founder & CEO",
    bio: "UCLA Computer Science & Engineering graduate. Built production systems at Microsoft (L62, MSN & Visual Studio), Amazon (SDE II, L5), T-Mobile, and Disney Consumer Products before founding Ejago. Co-founded Kompit — the official scoring platform adopted by the Indonesian National Olympic Committee across martial arts including Taekwondo, Boxing, and Pencak Silat. Kompit was acquired by Djarum, Indonesia's largest conglomerate (parent of BCA, the nation's largest bank). Currently runs Jago Hemat and KOI Designer Scrubs (apparel), co-owns Qubis (calories & nutrition tracking), Kompit, and holds equity in HelloCaddy. Volunteers at church. Plays piano and chess. Builds with the conviction that technology and performance advertising should compound together — not operate in silos.",
    image: "/indra-headshot-1.jpg",
  },
  {
    name: "Lin Wei",
    role: "Co-Founder & CTO",
    bio: "Former senior engineer at two YC-backed startups. Obsessed with developer experience and code quality. Runs the engineering and AI automation practice.",
    focus: "Engineering, AI Systems, Technical Direction",
  },
  {
    name: "Sarah Chen",
    role: "Head of Performance",
    bio: "Managed $40M+ in ad spend across Google, Meta, and TikTok. Joined after Ejago cut their CAC by 60% in 90 days — couldn't resist joining the team that actually knows AI.",
    focus: "Google Ads, Meta Ads, TikTok Ads, Analytics",
  },
  {
    name: "Priya Sharma",
    role: "Lead Designer",
    bio: "Design systems are her love language. Previously at a fintech unicorn. Brings premium UX thinking to every project — because beautiful and functional aren't opposites.",
    focus: "UI/UX Design, Design Systems, Brand",
  },
];

const values = [
  {
    title: "Ship or Don't",
    desc: "We're not a consultancy. We build. If it's not in production, it doesn't count. We measure success by outcomes shipped, not decks presented.",
    icon: "🚀",
  },
  {
    title: "AI That's Real",
    desc: "We don't bolt ChatGPT onto a spreadsheet and call it AI automation. Every system we build is designed to actually replace manual work — end to end.",
    icon: "🧠",
  },
  {
    title: "Full-Stack Thinking",
    desc: "Your website talks to your CRM. Your ads talk to your analytics. Your AI talks to both. Everything we build is built to work together — because that's where the compounding is.",
    icon: "⚡",
  },
  {
    title: "No Black Boxes",
    desc: "You'll always know what we're building, why we're building it, and what it's supposed to cost. Weekly updates. Transparent reporting. Always.",
    icon: "🔍",
  },
];
---

<Layout
  title="About Ejago — We're the Convergence Agency | Los Angeles"
  description="Ejago is a Los Angeles digital agency that fuses AI automation with performance advertising. Founded in 2011 to solve the problem of fragmented agency relationships."
>
  <Header client:load />

  <!-- Hero -->
  <section class="min-h-[70vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full blur-3xl animate-mesh-1"
           style="background: radial-gradient(circle, rgba(124,58,237,0.3) 0%, transparent 70%);" />
      <div class="absolute bottom-0 left-0 w-[600px] h-[600px] rounded-full blur-3xl animate-mesh-3"
           style="background: radial-gradient(circle, rgba(245,158,11,0.25) 0%, transparent 70%);" />
    </div>

    <div class="relative z-10 max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 w-full">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--accent);">
          About Ejago
        </p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight"
            style="font-family: var(--font-display); color: var(--text);">
          The Agency That Got<br/>
          <span style="color: var(--accent);">Tired of Agencies.</span>
        </h1>
        <p class="text-lg md:text-xl"
           style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
          We started Ejago because we kept watching the same story repeat: founders hire a dev shop, then an ad agency, then an AI consultant — and end up with three vendors, zero integration, and a lot of missed calls.
        </p>
        <p class="text-lg md:text-xl mt-4"
           style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
          We decided to be the last agency you'd ever need. One team. Every growth lever. Built to work together.
        </p>
      </div>
    </div>
  </section>

  <!-- Story section -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--accent);">
            Our Story
          </p>
          <h2 class="text-3xl md:text-5xl mb-8" style="font-family: var(--font-display); color: var(--text);">
            From Web Shop to<br/>Convergence Agency
          </h2>
          <div class="space-y-6" style="color: var(--text-secondary); line-height: 1.8;">
            <p>
              Ejago started in 2020 as a standard web development shop — we built websites, we shipped on time, we were good at it. But every client told us the same thing: <em>"Can you also run our ads?"</em> Then: <em>"Can you also automate our ops?"</em>
            </p>
            <p>
              Instead of saying no, we said yes — and then we figured out how to say yes well. We started hiring ads specialists. Then AI engineers. We stopped treating websites and ad campaigns as separate disciplines and started treating them as one system.
            </p>
            <p>
              The insight that changed everything: <strong style="color: var(--text);">your ad data should inform your product, and your product should generate data for your ads.</strong> When those two things work together, growth becomes compounding instead of exhausting.
            </p>
            <p>
              Today, Ejago is the only agency in Los Angeles that builds the full stack — product, AI, and paid media — and actually makes them work as one machine.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { stat: "2020", label: "Founded in Los Angeles" },
            { stat: "60+", label: "Projects delivered" },
            { stat: "12", label: "Team members" },
            { stat: "4", label: "Avg. years per client" },
          ].map(s => (
            <div class="p-6 rounded-2xl text-center" style="background-color: var(--surface-alt); border: 1px solid var(--border);">
              <div class="text-3xl font-bold mb-2" style="font-family: var(--font-mono); color: var(--accent);">{s.stat}</div>
              <div class="text-sm" style="color: var(--text-secondary);">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--accent);">
          How We Work
        </p>
        <h2 class="text-3xl md:text-5xl" style="font-family: var(--font-display); color: var(--text);">
          Four Principles We Don't Compromise On
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {values.map(v => (
          <div class="p-8 rounded-2xl" style="background-color: var(--surface); border: 1px solid var(--border);">
            <div class="text-3xl mb-4">{v.icon}</div>
            <h3 class="text-xl font-bold mb-3" style="font-family: var(--font-display); color: var(--text);">{v.title}</h3>
            <p class="text-base" style="color: var(--text-secondary); line-height: 1.7;">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 md:py-28" style="background-color: var(--surface);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--accent);">
          The Team
        </p>
        <h2 class="text-3xl md:text-5xl mb-4" style="font-family: var(--font-display); color: var(--text);">
          Real Humans. Real Builders.
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
          Not a roster of names with fake titles. These are the people who will actually be working on your project.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {team.map(t => (
          <div class="flex gap-6 p-6 rounded-2xl" style="background-color: var(--surface-alt); border: 1px solid var(--border);">
            <!-- Avatar placeholder -->
            <div class="w-20 h-20 rounded-full flex-shrink-0 flex items-center justify-center text-2xl font-bold"
                 style="background: linear-gradient(135deg, var(--accent), var(--amber)); color: white; font-family: var(--font-display);">
              {t.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <h3 class="text-lg font-bold mb-1" style="color: var(--text);">{t.name}</h3>
              <p class="text-sm font-medium mb-3" style="color: var(--accent);">{t.role}</p>
              <p class="text-sm mb-3" style="color: var(--text-secondary); line-height: 1.6;">{t.bio}</p>
              <p class="text-xs font-medium" style="color: var(--text-secondary);">
                <span style="color: var(--amber);">Focus:</span> {t.focus}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why LA -->
  <section class="py-20 md:py-28" style="background-color: var(--bg);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--accent);">
            Los Angeles
          </p>
          <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: var(--text);">
            Why LA Is Our Home
          </h2>
          <div class="space-y-4" style="color: var(--text-secondary); line-height: 1.8;">
            <p>
              Los Angeles is where the smartest founders, creators, and brands are building right now. From Venice Beach tech startups to DTLA CPG brands to the world's most-followed creators — the companies shaping the next decade of culture are being built in this city.
            </p>
            <p>
              We built Ejago here because we wanted to work with the companies that are doing things that have never been done. We're not interested in building another SaaS dashboard for a B2B software company. We're interested in the brand that hasn't launched yet, the product that doesn't exist, the growth system that hasn't been designed.
            </p>
            <p>
              <strong style="color: var(--text);">We work with founders who are serious about compounding.</strong> If that sounds like you — let's talk.
            </p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden h-80 relative" style="border: 1px solid var(--border);">
          <img
            src="https://images.unsplash.com/photo-1534190760961-74e8c1c5c3da?w=800&q=80"
            alt="Los Angeles skyline at dusk"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,10,14,0.6) 0%, transparent 60%);" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32" style="background-color: var(--accent);">
    <div class="max-w-[85vw] mx-auto px-6 md:px-10 lg:px-16 text-center">
      <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">
        Let's Build Together
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.8);">
        If you have a project, a growth problem, or just an idea you're kicking around — we'd love to hear it. No commitment required. Just a real conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact"
           class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: white; color: var(--accent);">
          Start a Project →
        </a>
        <a href="https://calendly.com/indra-ejago"
           target="_blank"
           class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg"
           style="background-color: transparent; color: white; border: 2px solid white;">
          Book a Call →
        </a>
      </div>
    </div>
  </section>

  <Footer client:load />
  <BackToTop client:load />
</Layout>
