---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Hero from '../components/Hero';
import TrustBar from '../components/TrustBar';
import ServicesGrid from '../components/ServicesGrid';
import HowItWorks from '../components/HowItWorks';
import CaseStudySpotlight from '../components/CaseStudySpotlight';
import ConvergenceEngine from '../components/ConvergenceEngine';
import StatsBar from '../components/StatsBar';
import Testimonials from '../components/Testimonials';
import FAQAccordion from '../components/FAQAccordion';
import BudgetCalculator from '../components/BudgetCalculator';
import BigFooterCTA from '../components/BigFooterCTA';
import Footer from '../components/Footer';
import BackToTop from '../components/BackToTop';
import ContactSection from '../components/ContactSection';
import SectionDivider from '../components/SectionDivider';
---

<Layout>
  <Header client:load />
  <main>
    <Hero client:load />
    <SectionDivider variant="glow" />
    <TrustBar client:load />
    <SectionDivider variant="line" />
    <ServicesGrid client:visible />
    <SectionDivider variant="glow" />
    <HowItWorks client:visible />
    <SectionDivider variant="line" />
    <CaseStudySpotlight client:visible />
    <SectionDivider variant="glow" />
    <ConvergenceEngine client:visible />
    <SectionDivider variant="line" />
    <StatsBar client:visible />
    <SectionDivider variant="glow" />
    <Testimonials client:visible />
    <SectionDivider variant="line" />
    <FAQAccordion client:idle />
    <SectionDivider variant="glow" />
    <BudgetCalculator client:idle />
  </main>
  <BigFooterCTA client:idle />
  <ContactSection client:idle />
  <Footer client:idle />
  <BackToTop client:idle />
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How fast can you deliver?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We move fast without cutting corners. Our typical timeline: Discovery and strategy (1 week), Design and prototyping (1-2 weeks), Development and testing (2-4 weeks), Launch and optimization (1 week). For urgent projects, we offer accelerated timelines with a dedicated sprint team. Most projects are live within 7-21 days."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our pricing scales with your ambitions. Website projects typically start at $8K, AI automation at $12K, and full-stack growth packages from $15K/month. We don't believe in one-size-fits-all pricing \u2014 every proposal is custom-built around your goals, competitive landscape, and growth targets. Book a call for a detailed breakdown. Starter from $8.5K/mo. Growth from $15K/mo."
      }
    },
    {
      "@type": "Question",
      "name": "What if I already tried AI and it failed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most AI failures come from poor implementation, not AI itself. We've rescued dozens of 'broken AI' setups and turned them into revenue generators. We start with a thorough audit of what didn't work, identify the gaps, and rebuild with proper data foundations, human oversight loops, and measurable KPIs. AI works \u2014 when it's done right."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with startups or only enterprises?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We love working with growth-stage companies (Series A to Series C) that are ready to scale. Our typical client: $1M-$20M ARR, has product-market fit, needs to accelerate growth but lacks internal bandwidth. We're not the right fit for early-stage idea phase or massive enterprise with slow procurement cycles. If you need to grow fast and make decisions quickly, we're built for that."
      }
    },
    {
      "@type": "Question",
      "name": "What's your process?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We start with a 2-week deep dive: competitive analysis, audience research, technical audit, and opportunity mapping. Then we present a custom growth strategy with clear milestones, timelines, and KPIs. Once aligned, we execute in focused sprints with weekly updates and real-time dashboards. No black boxes, no mystery \u2014 just transparent execution and measurable results."
      }
    },
    {
      "@type": "Question",
      "name": "What happens after launch?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Launch is just the beginning. We provide 30 days of dedicated support post-launch to squash any bugs and optimize performance. Beyond that, most clients stay on our retainer for ongoing optimization. We set up monitoring dashboards so you can see real-time performance, and we conduct monthly strategy reviews to keep iterating and improving. We're in it for the long haul."
      }
    }
  ]
}
</script>
</Layout>
