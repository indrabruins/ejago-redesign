---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import BackToTop from '../components/BackToTop';

const services = [
  {
    slug: "website-development",
    icon: "🌐",
    title: "Website Development",
    tagline: "Products, not brochures.",
    desc: "We build digital products that are designed to convert from day one. Every line of code serves a purpose.",
    highlights: ["Custom Websites", "E-commerce", "Web Applications", "Progressive Web Apps", "CMS Integration", "Performance Optimization"],
    href: "/services/website-development",
    color: "#7C3AED",
  },
  {
    slug: "mobile-apps",
    icon: "📱",
    title: "Mobile Apps",
    tagline: "Native and cross-platform.",
    desc: "iOS, Android, or React Native — mobile experiences that people actually keep on their phones.",
    highlights: ["iOS Development", "Android Development", "React Native", "App Store Optimization", "Push Notifications", "API Integration"],
    href: "#",
    color: "#3B82F6",
  },
  {
    slug: "custom-integrations",
    icon: "🔗",
    title: "Custom Integrations",
    tagline: "Your tools, connected.",
    desc: "We wire your entire stack into a seamless operational nervous system.",
    highlights: ["API Development", "CRM Integrations", "Marketing Automation", "Third-Party Connections", "Data Pipelines", "Webhooks"],
    href: "#",
    color: "#F59E0B",
  },
  {
    slug: "ai-automation",
    icon: "🧠",
    title: "AI Automation",
    tagline: "The work that kills momentum — automated.",
    desc: "We identify manual processes, build AI workflows to automate them, and give your team their hours back.",
    highlights: ["AI Agent Development", "Workflow Automation", "Document Processing", "Customer Service AI", "Predictive Analytics", "AI Integration"],
    href: "/services/ai-automation",
    color: "#10B981",
  },
  {
    slug: "google-ads",
    icon: "🔍",
    title: "Google Ads",
    tagline: "Every dollar tracked, tested, and optimized.",
    desc: "Search, Display, Shopping, YouTube, Performance Max — managed with AI-powered targeting.",
    highlights: ["Search Campaigns", "Performance Max", "Display Advertising", "YouTube Ads", "Shopping Campaigns", "AI-Optimized Bidding"],
    href: "/services/google-ads",
    color: "#EF4444",
  },
  {
    slug: "meta-tiktok-ads",
    icon: "📣",
    title: "Meta & TikTok Ads",
    tagline: "Where your customers actually are.",
    desc: "Precision-targeted campaigns built on real audience insights — Facebook, Instagram, and TikTok.",
    highlights: ["Facebook Ads", "Instagram Ads", "TikTok Ads", "Retargeting", "Lead Generation", "Creative Strategy"],
    href: "#",
    color: "#EC4899",
  },
];
---

<Layout
  title="Services — Ejago | Websites, Apps, AI, Google Ads, Meta & TikTok Ads"
  description="Full-stack digital services: websites, mobile apps, custom integrations, AI automation, Google Ads, Meta & TikTok Ads. One agency. Every growth lever."
>
  <Header client:load />

  <!-- Hero -->
  <section class="min-h-[60vh] flex items-center pt-32 pb-20 relative overflow-hidden" style="background-color: var(--bg);">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full blur-3xl animate-mesh-1"
           style="background: radial-gradient(circle, rgba(124,58,237,0.25) 0%, transparent 70%);" />
      <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full blur-3xl animate-mesh-2"
           style="background: radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);" />
    </div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 w-full">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--accent);">Services</p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl mb-6 leading-tight" style="font-family: var(--font-display); color: var(--text);">
          Every Growth Lever.<br/><span style="color: var(--accent);">One Agency.</span>
        </h1>
        <p class="text-lg md:text-xl" style="color: var(--text-secondary); line-height: 1.7; max-width: 650px;">
          Most agencies do one thing well. We do six — and we built them to work together. That's the compounding difference.
        </p>
      </div>
    </div>
  </section>

  <!-- Convergence bar -->
  <section class="py-16 border-y" style="border-color: var(--border); background-color: var(--surface);">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        {[
          { title: "The Convergence Play", desc: "AI informs your ads. Your ads generate data for your AI. Everything compounds.", color: "#7C3AED" },
          { title: "Fixed Scope, Fixed Price", desc: "You get a clear quote before we start. No scope creep. No surprise invoices.", color: "#F59E0B" },
          { title: "7-Day First Delivery", desc: "Something tangible in your hands within a week. Not a proposal — a prototype.", color: "#10B981" },
        ].map(f => (
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2" style={`color: ${f.color};`}>{f.title}</h3>
            <p class="text-sm" style="color: var(--text-secondary);">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-20 md:py-32" style="background-color: var(--bg);">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a
            href={s.href}
            class="group p-8 rounded-2xl transition-all duration-300 hover:-translate-y-2"
            style={`background-color: var(--surface); border: 1px solid var(--border);`}
          >
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="text-xl font-bold mb-2" style="font-family: var(--font-display); color: var(--text);">{s.title}</h3>
            <p class="text-sm font-medium mb-3" style={`color: ${s.color};`}>{s.tagline}</p>
            <p class="text-sm mb-6" style="color: var(--text-secondary); line-height: 1.6;">{s.desc}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {s.highlights.slice(0,3).map(h => (
                <span class="px-3 py-1 rounded-full text-xs font-medium" style="background-color: rgba(124,58,237,0.08); color: var(--accent);">{h}</span>
              ))}
            </div>
            <span class="flex items-center gap-1 text-sm font-semibold group-hover:gap-2 transition-all" style={`color: ${s.color};`}>
              Learn more →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32" style="background-color: var(--accent);">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16 text-center">
      <h2 class="text-3xl md:text-5xl mb-6" style="font-family: var(--font-display); color: white;">Ready to Start?</h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: rgba(255,255,255,0.8);">Tell us what you're building. We'll tell you exactly how we'd approach it — no pitch, no commitment.</p>
      <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-lg" style="background-color: white; color: var(--accent);">Start a Project →</a>
    </div>
  </section>

  <Footer client:load />
  <BackToTop client:load />
</Layout>
